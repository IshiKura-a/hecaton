# Copy this file to .env and fill in.
# .env is gitignored — never commit real values.

# ---- Tailscale -------------------------------------------------------------
# Auth key for the host-level tailscaled installed by
# bootstrap/network/10-install-tailscale.sh. Reusable, pre-approved.
# Generated at: https://login.tailscale.com/admin/settings/keys
TS_AUTHKEY=

# Extra flags appended verbatim to `tailscale up` on every host. Any tag
# referenced here must already exist in `tagOwners` in the live tailnet
# policy, otherwise `tailscale up` will fail.
TS_EXTRA_ARGS=

# Auth key for the in-cluster Tailscale subnet router pod (advertises
# the cluster pod CIDR into the tailnet so trainers can reach sandbox
# pods directly). Must be created with tag:fleet-subnet so that the
# tailnet policy's autoApprovers accepts the route automatically.
TS_AUTHKEY_SUBNET_ROUTER=

# Auth key for trainer containers / hosts. Consumed by
# scripts/setup-trainer.sh (and the trainer Dockerfile's
# trainer-entrypoint.sh) when bringing a trainer into the tailnet.
# Generate with: Reusable + Ephemeral + Pre-approved + tag:trainer.
TS_AUTHKEY_TRAINER=

# ---- Broker ---------------------------------------------------------------
# Container image URI for the trainer-facing broker.
#
# Two ways to provide it:
#
#   1. CI build via GitHub Actions (production):
#      .github/workflows/broker-image.yml builds + pushes on every
#      change under platform/broker/. Set BROKER_IMAGE to a tag the
#      action produced, e.g.
#        ghcr.io/<owner>/hecaton-broker:<sha>
#        ghcr.io/<owner>/hecaton-broker:latest
#      Fleet nodes pull directly from ghcr.io (verified reachable).
#      NOTE: ghcr.io references must be all lowercase; if your GitHub
#      handle has uppercase letters, lowercase it here.
#
#   2. Local build + scp + import (offline / dev):
#        bash platform/broker/build-and-import.sh
#      Leave BROKER_IMAGE unset or use the script's default
#      `docker.io/library/hecaton-broker:dev`. bootstrap/install.sh
#      runs build-and-import.sh before 26 so this path is the default
#      when BROKER_IMAGE is unset.
BROKER_IMAGE=

# Shared bearer token trainers send to the broker. Generate with e.g.
# `openssl rand -hex 32`. The same value goes into trainer environments
# as HECATON_TOKEN.
HECATON_TOKEN=

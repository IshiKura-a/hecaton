{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "panels": [
    {
      "type": "timeseries",
      "title": "Sandbox pod phases",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Pods in hecaton-sandboxes grouped by phase. Sustained Pending = scheduler stuck; Failed = check restart reasons below.",
      "targets": [
        {
          "expr": "sum by (phase) (kube_pod_status_phase{namespace=\"hecaton-sandboxes\"}) > 0",
          "legendFormat": "{{phase}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "stacking": {
              "mode": "normal"
            }
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Container restarts (per minute)",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (pod) (rate(kube_pod_container_status_restarts_total{namespace=\"hecaton-sandboxes\"}[5m])) * 60",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "table",
      "title": "Sandbox pod health (current)",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "kube-state-metrics view of every pod in hecaton-sandboxes \u2014 phase, restart count, last terminated reason.",
      "targets": [
        {
          "expr": "sum by (pod, phase) (kube_pod_status_phase{namespace=\"hecaton-sandboxes\"}) > 0",
          "refId": "A",
          "instant": true,
          "format": "table"
        },
        {
          "expr": "sum by (pod) (kube_pod_container_status_restarts_total{namespace=\"hecaton-sandboxes\"})",
          "refId": "B",
          "instant": true,
          "format": "table"
        },
        {
          "expr": "sum by (pod, reason) (kube_pod_container_status_last_terminated_reason{namespace=\"hecaton-sandboxes\"}) > 0",
          "refId": "C",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "merge"
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "service": true,
              "namespace": true,
              "instance": true
            }
          }
        }
      ]
    },
    {
      "type": "table",
      "title": "All sandboxes (live)",
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 24,
        "h": 10
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "hecaton_sandbox_age_seconds",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "service": true,
              "namespace": true
            }
          }
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "agent-sandbox controller (reconcile rate + errors)",
      "gridPos": {
        "x": 0,
        "y": 26,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Reconcile activity from controller-runtime. Errors trending up = controller can't keep up or is hitting persistent failures.",
      "targets": [
        {
          "expr": "sum by (controller) (rate(controller_runtime_reconcile_total{controller=~\"sandbox|sandboxclaim|sandboxtemplate|sandboxwarmpool\"}[5m])) * 60",
          "legendFormat": "reconcile/min {{controller}}",
          "refId": "A"
        },
        {
          "expr": "sum by (controller) (rate(controller_runtime_reconcile_errors_total{controller=~\"sandbox|sandboxclaim|sandboxtemplate|sandboxwarmpool\"}[5m])) * 60",
          "legendFormat": "errors/min {{controller}}",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "agent-sandbox controller (work queue depth)",
      "gridPos": {
        "x": 12,
        "y": 26,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Backlog in the reconcile work queue. Sustained non-zero = reconciler is throttled.",
      "targets": [
        {
          "expr": "workqueue_depth{name=~\"sandbox|sandboxclaim|sandboxtemplate|sandboxwarmpool\"}",
          "legendFormat": "{{name}}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": [
    "hecaton"
  ],

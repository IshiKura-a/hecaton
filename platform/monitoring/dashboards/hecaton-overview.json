{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [
    { "title": "Acquire Health", "url": "/d/hecaton-acquires", "type": "link" },
    { "title": "Capacity", "url": "/d/hecaton-capacity", "type": "link" },
    { "title": "Lifecycle", "url": "/d/hecaton-lifecycle", "type": "link" },
    { "title": "Nodes", "url": "/d/hecaton-nodes", "type": "link" }
  ],
  "panels": [
    {
      "type": "stat",
      "title": "Sandboxes",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(hecaton_sandboxes) or vector(0)", "refId": "A", "instant": true }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "type": "stat",
      "title": "Active runs",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "count(count by (run_id) (hecaton_sandboxes)) or vector(0)", "refId": "A", "instant": true }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "type": "stat",
      "title": "Trainers",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "hecaton_trainers", "refId": "A", "instant": true }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "type": "stat",
      "title": "GPU headroom",
      "description": "Allocatable GPUs minus requested. Red = fleet full.",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(kube_node_status_allocatable{resource=\"nvidia_com_gpu\"}) - (sum(kube_pod_container_resource_requests{resource=\"nvidia_com_gpu\"}) or vector(0))", "refId": "A", "instant": true }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "green", "value": 2 }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Acquires / 5m",
      "gridPos": { "x": 16, "y": 0, "w": 3, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(increase(hecaton_acquires_total[5m])) or vector(0)", "refId": "A", "instant": true }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "type": "stat",
      "title": "Failures / 5m",
      "gridPos": { "x": 19, "y": 0, "w": 3, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(increase(hecaton_acquire_failures_total[5m])) or vector(0)", "refId": "A", "instant": true }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Success rate",
      "gridPos": { "x": 22, "y": 0, "w": 2, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "(sum(increase(hecaton_acquires_total[5m])) > 0) / (sum(increase(hecaton_acquires_total[5m])) + sum(increase(hecaton_acquire_failures_total[5m])))", "refId": "A", "instant": true }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "noValue": "N/A",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.9 },
              { "color": "green", "value": 0.99 }
            ]
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Sandboxes by template",
      "gridPos": { "x": 0, "y": 4, "w": 16, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by (template) (hecaton_sandboxes)", "legendFormat": "{{template}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "stacking": { "mode": "normal" }, "fillOpacity": 20 } } }
    },
    {
      "type": "stat",
      "title": "Oldest sandbox",
      "description": "Age of the longest-held sandbox. Alert if > 2h (reaper should have cleaned it).",
      "gridPos": { "x": 16, "y": 4, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "max(hecaton_sandbox_age_seconds) or vector(0)", "refId": "A", "instant": true }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 3600 },
              { "color": "red", "value": 7200 }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Acquire p95",
      "description": "95th percentile acquire latency (last 5m). High = cold-start or scheduling delay.",
      "gridPos": { "x": 20, "y": 4, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(hecaton_acquire_latency_seconds_bucket[5m])))", "refId": "A", "instant": true }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "noValue": "idle",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 30 },
              { "color": "red", "value": 120 }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Controller errors",
      "description": "Reconcile errors in last 5m. Non-zero = check Lifecycle dashboard.",
      "gridPos": { "x": 16, "y": 8, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(increase(controller_runtime_reconcile_errors_total{controller=\"sandbox\"}[5m])) or vector(0)", "refId": "A", "instant": true }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "type": "stat",
      "title": "Nodes ready",
      "gridPos": { "x": 20, "y": 8, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(kube_node_status_condition{condition=\"Ready\",status=\"true\"})", "refId": "A", "instant": true }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["hecaton"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "title": "Hecaton Overview",
  "uid": "hecaton-overview",
  "version": 3
}
